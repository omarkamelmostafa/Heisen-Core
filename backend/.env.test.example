# ━━━ MongoDB Memory Server (for testing) ━━━
# Directory to store MongoDB binaries for tests
MONGOMS_DOWNLOAD_DIR=./.mongodb-binaries

# MongoDB version to use for tests
MONGOMS_VERSION=6.0.6

# Disable postinstall hook (recommended for CI)
MONGOMS_DISABLE_POSTINSTALL=1

# Prefer global path for MongoDB binaries
MONGOMS_PREFER_GLOBAL_PATH=0
