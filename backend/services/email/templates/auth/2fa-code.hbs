<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Two-Factor Authentication Code</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      line-height: 1.6;
      color: #444444;
      max-width: 600px;
      margin: 0 auto;
      padding: 32px 16px;
      background-color: #f4f4f4;
    }
    .card {
      background-color: #ffffff;
      border-radius: 10px;
      border: 1px solid #e4e4e4;
      overflow: hidden;
    }
    .header {
      background-color: #111111;
      padding: 28px 40px;
    }
    .header-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888888;
      margin: 0 0 6px;
      display: block;
    }
    .header h1 {
      color: #ffffff;
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.2px;
    }
    .body {
      padding: 36px 40px 40px;
    }
    .greeting {
      font-size: 16px;
      color: #111111;
      font-weight: 500;
      margin: 0 0 12px;
    }
    .body p {
      font-size: 15px;
      color: #555555;
      margin: 0 0 0;
      line-height: 1.7;
    }
    .otp-block {
      text-align: center;
      margin: 32px 0;
      padding: 32px 20px;
      background-color: #f7f7f7;
      border-radius: 8px;
      border: 1px dashed #cccccc;
    }
    .otp-code {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: 12px;
      color: #111111;
      margin: 0 0 10px;
      font-family: 'Courier New', Courier, monospace;
      display: block;
    }
    .otp-label {
      font-size: 11px;
      color: #999999;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1.2px;
    }
    .divider {
      border: none;
      border-top: 1px solid #eeeeee;
      margin: 28px 0;
    }
    .expiry-note {
      font-size: 13px;
      color: #888888;
      margin: 0 0 0;
    }
    .warning-block {
      font-size: 13px;
      color: #777777;
      border-left: 3px solid #e4e4e4;
      padding: 10px 14px;
      margin: 20px 0 0;
      background-color: #fafafa;
      border-radius: 0 6px 6px 0;
    }
    .footer {
      margin-top: 24px;
      font-size: 12px;
      color: #aaaaaa;
      text-align: center;
      line-height: 1.8;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <span class="header-label">Security</span>
      <h1>Two-Factor Authentication</h1>
    </div>
    <div class="body">
      <p class="greeting">Hello {{user.firstName}},</p>
      <p>Use the verification code below to complete your sign-in. Do not share this code with anyone.</p>

      <div class="otp-block">
        <span class="otp-code">{{twoFactorCode}}</span>
        <p class="otp-label">One-time verification code</p>
      </div>

      <p class="expiry-note">This code expires in <strong>{{expiryMinutes}} minutes</strong>. After that, sign in again to receive a new one.</p>

      <hr class="divider">

      <div class="warning-block">
        If you did not attempt to sign in, change your password immediately — your account may be at risk.
      </div>
    </div>
  </div>
  <div class="footer">
    <p>This is an automated message. Please do not reply to this email.</p>
  </div>
</body>
</html>
