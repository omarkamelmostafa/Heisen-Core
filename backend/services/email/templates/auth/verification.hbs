<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      line-height: 1.6;
      color: #444444;
      max-width: 600px;
      margin: 0 auto;
      padding: 32px 16px;
      background-color: #f4f4f4;
    }
    .card {
      background-color: #ffffff;
      border-radius: 10px;
      border: 1px solid #e4e4e4;
      overflow: hidden;
    }
    .header {
      background-color: #111111;
      padding: 28px 40px;
    }
    .header-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888888;
      margin: 0 0 6px;
      display: block;
    }
    .header h1 {
      color: #ffffff;
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.2px;
    }
    .body {
      padding: 36px 40px 40px;
    }
    .greeting {
      font-size: 16px;
      color: #111111;
      font-weight: 500;
      margin: 0 0 12px;
    }
    .body p {
      font-size: 15px;
      color: #555555;
      margin: 0;
      line-height: 1.7;
    }
    .code-block {
      text-align: center;
      margin: 32px 0;
      padding: 32px 20px;
      background-color: #f7f7f7;
      border-radius: 8px;
      border: 1px dashed #cccccc;
    }
    .code-block span {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: 12px;
      color: #111111;
      display: block;
      margin: 0 0 10px;
      font-family: 'Courier New', Courier, monospace;
    }
    .code-block p {
      font-size: 11px;
      color: #999999;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1.2px;
    }
    .divider {
      border: none;
      border-top: 1px solid #eeeeee;
      margin: 28px 0;
    }
    .expiry-note {
      font-size: 13px;
      color: #888888;
      margin: 0 0 0;
    }
    .ignore-note {
      font-size: 13px;
      color: #999999;
      margin: 12px 0 0;
    }
    .footer {
      margin-top: 24px;
      font-size: 12px;
      color: #aaaaaa;
      text-align: center;
      line-height: 1.8;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <span class="header-label">Account Setup</span>
      <h1>Verify Your Email</h1>
    </div>
    <div class="body">
      <p class="greeting">Hello {{user.firstName}},</p>
      <p>Welcome! To complete your registration and activate your account, enter the verification code below.</p>

      <div class="code-block">
        <span>{{verificationCode}}</span>
        <p>Your one-time verification code</p>
      </div>

      <p class="expiry-note">This code is valid for <strong>24 hours</strong>. If it expires, request a new one from the verification screen.</p>

      <hr class="divider">

      <p class="ignore-note">If you didn't create an account, you can safely ignore this email — nothing will change.</p>
    </div>
  </div>
  <div class="footer">
    <p>This is an automated message. Please do not reply to this email.</p>
  </div>
</body>
</html>

