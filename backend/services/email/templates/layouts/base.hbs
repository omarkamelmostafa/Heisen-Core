<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    /* Base styles that can be extended */
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: linear-gradient(to right, #4CAF50, #45a049); padding: 20px; text-align: center; }
    .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    .footer { text-align: center; margin-top: 20px; color: #888; font-size: 0.8em; }
  </style>
</head>
<body>
  <div class="header">
    <h1 style="color: white; margin: 0;">{{headerTitle}}</h1>
  </div>
  <div class="content">
    {{{body}}}
  </div>
  <div class="footer">
    <p>This is an automated message, please do not reply to this email.</p>
  </div>
</body>
</html>