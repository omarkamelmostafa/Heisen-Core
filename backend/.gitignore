# ============================================================
# Backend .gitignore
# ============================================================

# Dependencies
node_modules/

# Environment Variables — NEVER commit secrets
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Runtime / Build
dist/
build/
tmp/
temp/

# OS Files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# History
.history/

# Debug / Temp files
*.tmp

# MongoDB Memory Server binary cache
.mongodb-binaries/
