							"name": "POST Login User",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test(\"Status code is 200\", function () {",
											"    pm.response.to.have.status(200);",
											"});",
											"pm.test(\"Login successful\", function () {",
											"    var jsonData = pm.response.json();",
											"    pm.expect(jsonData).to.have.property('success', true);",
											"    pm.expect(jsonData.data).to.have.property('accessToken');",
											"    pm.expect(jsonData.data).to.have.property('user');",
											"});",
											"pm.test(\"Refresh token cookie set\", function () {",
											"    var refreshTokenCookie = pm.cookies.get('refreshToken');",
											"    pm.expect(refreshTokenCookie).to.not.be.null;",
											"});",
											"// Store tokens for future requests",
											"if (pm.response.code === 200) {",
											"    var jsonData = pm.response.json();",
											"    pm.collectionVariables.set('access_token', jsonData.data.accessToken);",
											"    pm.collectionVariables.set('user_id', jsonData.data.user.id);",
											"}"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
