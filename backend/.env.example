# ============================================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
# ============================================================

# DATABASE CONNECTION

# Connection Mode - "local" or "atlas"
DB_CONNECTION_MODE=local
# DB_CONNECTION_MODE=atlas

# Local Database Configuration
DB_LOCAL_HOST=127.0.0.1
DB_LOCAL_PORT=27017
DB_LOCAL_NAME=fantasy-coach
DB_LOCAL_USER=
DB_LOCAL_PASSWORD=

# Atlas Database Configuration
DATABASE_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appname>
DB_ATLAS_NAME=fantasy-coach


# TOKEN CONFIGURATION

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=<generate-64-byte-hex-secret>
REFRESH_TOKEN_SECRET=<generate-64-byte-hex-secret>

# Token Expiration
ACCESS_TOKEN_EXPIRY=60m
REFRESH_TOKEN_EXPIRY=1d
REFRESH_TOKEN_COOKIE_MAX_AGE=86400000
ACCESS_TOKEN_COOKIE_NAME="accessToken"
REFRESH_TOKEN_COOKIE_NAME="refreshToken"

# JWT Configuration
JWT_ISSUER=fantasy-coach-app-backend-v1
JWT_AUDIENCE=fantasy-coach-app-web-client
REDIS_URL=redis://localhost:6379

# SERVER
PORT=4000
API_URL="http://localhost:4000/api/v1/"
BASE_URL="http://localhost:4000/"
SCRAPER_BASE_URL="http://localhost:5000/api/v1"
NODE_ENV="development"
# NODE_ENV="production"


# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:4000,http://localhost:3000,http://localhost:5173
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization,X-API-Key
EXPOSED_HEADERS=X-Total-Count,X-API-Version


# CLOUDINARY
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# MAILTRAP (EMAIL SERVICE)
MAILTRAP_ENDPOINT=https://send.api.mailtrap.io/
MAILTRAP_TOKEN=<your-mailtrap-token>

