# ━━━ Server ━━━
NODE_ENV=development
PORT=4000

# ━━━ Database ━━━
DB_CONNECTION_MODE=local
# Local MongoDB
DB_LOCAL_HOST=localhost
DB_LOCAL_PORT=27017
DB_LOCAL_NAME=new-starter
DB_LOCAL_USER=
DB_LOCAL_PASSWORD=
# Atlas MongoDB (required if DB_CONNECTION_MODE=atlas)
DATABASE_URI=
DB_ATLAS_NAME=new-starter

# ━━━ Authentication (REQUIRED) ━━━
ACCESS_TOKEN_SECRET=your-access-token-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=new-starter-backend-v1
JWT_AUDIENCE=new-starter-web-client

# ━━━ Email — Ethereal (https://ethereal.email) ━━━
# Create a free account at ethereal.email to get credentials
# View sent emails at https://ethereal.email/messages
ETHEREAL_HOST=smtp.ethereal.email
ETHEREAL_PORT=587
ETHEREAL_USER=your_ethereal_username
ETHEREAL_PASS=your_ethereal_password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=New Starter Kit

# ━━━ Email — Mailtrap (for testing) ━━━
# MAILTRAP_ENDPOINT=https://sandbox.api.mailtrap.io/api
# MAILTRAP_TEST_INBOX_ID=your_inbox_id
# MAILTRAP_TOKEN=your_mailtrap_token

# ━━━ Cloudinary (for image uploads) ━━━
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ━━━ CORS ━━━
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization,X-API-Key,X-Request-ID
EXPOSED_HEADERS=X-Total-Count,X-API-Version

# Frontend URL for email redirect links (password reset, email change, etc.)
FRONTEND_URL=http://localhost:3000

# ━━━ Redis (for email queue) ━━━
REDIS_HOST=localhost
REDIS_PORT=6379

# ━━━ Cookies ━━━
COOKIE_DOMAIN=

# ━━━ Logging ━━━
LOG_LEVEL=info

# ━━━ Rate Limiting ━━━
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_FORGOT_MAX=3
RATE_LIMIT_FORGOT_WINDOW_MS=3600000
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW_MS=60000

# ━━━ Auth ━━━
REFRESH_TOKEN_EXPIRY=7d
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_MAX_AGE=86400000

# ━━━ Client / Frontend URL ━━━
CLIENT_URL=http://localhost:3000

# ━━━ API Configuration ━━━
API_URL=http://localhost:4000/api/v1/
BASE_URL=http://localhost:4000/
SCRAPER_BASE_URL=http://localhost:5000/api/v1

# ━━━ Redis URL (alternative format) ━━━
# REDIS_URL=redis://localhost:6379

COOKIE_DOMAIN=
