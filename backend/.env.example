# ━━━ Server ━━━
NODE_ENV=development
PORT=4000

# ━━━ Database ━━━
DB_CONNECTION_MODE=local
# Local MongoDB
DB_LOCAL_HOST=localhost
DB_LOCAL_PORT=27017
DB_LOCAL_NAME=new-starter
DB_LOCAL_USER=
DB_LOCAL_PASSWORD=
# Atlas MongoDB (required if DB_CONNECTION_MODE=atlas)
DATABASE_URI=
DB_ATLAS_NAME=new-starter

# ━━━ Authentication (REQUIRED) ━━━
ACCESS_TOKEN_SECRET=your-access-token-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=new-starter-backend-v1
JWT_AUDIENCE=new-starter-web-client

# ━━━ Email — Ethereal (https://ethereal.email) ━━━
# Create a free account at ethereal.email to get credentials
# View sent emails at https://ethereal.email/messages
ETHEREAL_HOST=smtp.ethereal.email
ETHEREAL_PORT=587
ETHEREAL_USER=your_ethereal_username
ETHEREAL_PASS=your_ethereal_password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=New Starter Kit

# ━━━ CORS ━━━
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL for email redirect links (password reset, email change, etc.)
FRONTEND_URL=http://localhost:3000

# ━━━ Redis (for email queue) ━━━
REDIS_HOST=localhost
REDIS_PORT=6379

# ━━━ Cookies ━━━
COOKIE_DOMAIN=

# ━━━ Logging ━━━
LOG_LEVEL=info

# ━━━ Rate Limiting ━━━
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_FORGOT_MAX=3
RATE_LIMIT_FORGOT_WINDOW_MS=3600000
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW_MS=60000

# ━━━ Auth ━━━
REFRESH_TOKEN_EXPIRY=7d
COOKIE_DOMAIN=
