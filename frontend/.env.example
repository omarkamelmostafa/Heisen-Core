# ━━━ App ━━━
# Port the Next.js dev server runs on
NEXT_PUBLIC_PORT=3000

# ━━━ App Environment ━━━
# Environment: development | production
NEXT_PUBLIC_APP_ENV=development

# ━━━ App Version ━━━
NEXT_PUBLIC_APP_VERSION=1

# ━━━ API ━━━
# Backend Express server URL (include /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000

# API Version
NEXT_PUBLIC_API_VERSION=1

# API Timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# API Retry Configuration
NEXT_PUBLIC_API_RETRY=true
NEXT_PUBLIC_API_RETRIES=3
NEXT_PUBLIC_API_RETRY_DELAY=1000

# ━━━ App URL ━━━
# Full URL of this frontend app (used for metadata, OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ━━━ NODE_ENV ━━━
# ⚠️ RESERVED - DO NOT SET MANUALLY
# Next.js automatically sets this based on the command:
# - `next dev` → development
# - `next build` → production
# Setting this manually will override NEXT_PUBLIC_APP_ENV and cause issues
