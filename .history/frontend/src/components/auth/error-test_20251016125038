"use client";

import { Button } from "@/components/ui/button";
import { AlertTriangle } from "lucide-react";

export function ErrorTestTrigger() {
  const triggerRealError = () => {
    // This will be caught by Next.js error boundary
    throw new Error("This is a REAL frontend runtime error for testing!");
  };

  const triggerUndefinedError = () => {
    // Accessing undefined property
    const obj = undefined;
    console.log(obj.nonExistentProperty); // This will throw
  };

  return (
    <div className="fixed top-20 right-4 bg-card border border-red-500 rounded-lg p-4 shadow-lg z-50">
      <div className="text-center space-y-3">
        <div className="flex items-center justify-center gap-2">
          <AlertTriangle className="h-4 w-4 text-red-500" />
          <span className="text-sm font-medium">Real Error Test</span>
        </div>
        
        <div className="space-y-2">
          <Button
            onClick={triggerRealError}
            size="sm"
            variant="destructive"
            className="w-full h-8 text-xs"
          >
            Throw Real Error
          </Button>
          <Button
            onClick={triggerUndefinedError}
            size="sm"
            variant="outline"
            className="w-full h-8 text-xs"
          >
            Undefined Access
          </Button>
        </div>
        
        <p className="text-[10px] text-muted-foreground">
          Tests Next.js error boundary
        </p>
      </div>
    </div>
  );
}