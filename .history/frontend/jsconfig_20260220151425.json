{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      // Core aliases
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/components/*": ["./src/components/*"],
      "@/services/*": ["./src/services/*"],
      "@/store/*": ["./src/store/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"],

      // UI specific
      "@/ui/*": ["./src/components/ui/*"],

      // Assets & Public
      "@/public/*": ["./public/*"]
    }
  },
  "include": ["src/**/*", "**/*.js", "**/*.jsx"],
  "exclude": ["node_modules", "build", "dist", ".next"]
}
